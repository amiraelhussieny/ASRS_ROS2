<ros2_control name="GazeboSystem" type="system">
  <hardware>
    <plugin>gz_ros2_control/GazeboSimSystem</plugin>
  </hardware>
  
  <joint name="wheel_x1_joint"><command_interface name="velocity"/><state_interface name="velocity"/></joint>
  <joint name="wheel_x2_joint"><command_interface name="velocity"/><state_interface name="velocity"/></joint>
  <joint name="wheel_x3_joint"><command_interface name="velocity"/><state_interface name="velocity"/></joint>
