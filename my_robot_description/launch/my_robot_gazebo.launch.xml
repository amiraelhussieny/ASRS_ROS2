<!-- Default launch file to test any urdf-file in Gazebo and Rviz -->
<launch>

    <!-- 1- Update your file name. ex: my_robot.urdf.xacro -->
    <let name="urdf_path" 
         value="$(find-pkg-share my_robot_description)/urdf/ros_shuttle.urdf.xacro" />

    <let name="rviz_config_path"
         value="$(find-pkg-share my_robot_description)/rviz/urdf_config.rviz" />

    <node pkg="robot_state_publisher" exec="robot_state_publisher">
        <param name="robot_description" value="$(command 'xacro $(var urdf_path)')" />
    </node>

    <node pkg="joint_state_publisher_gui" exec="joint_state_publisher_gui"/>

    <!-- 2- Update the Gazebo resource path. ex: /home/amira/test_urdf_gazebo/src -->
    <set_env name="GZ_SIM_RESOURCE_PATH" value="/home/amira/test_urdf_gazebo/src" />
    
    <include file="$(find-pkg-share ros_gz_sim)/launch/gz_sim.launch.py"> 
        <arg name="gz_args" value="empty.sdf" />
    </include>

    <node pkg="ros_gz_sim" exec="create" args="-topic robot_description" />

<node pkg="controller_manager" exec="ros2_control_node" output="screen">
    <param name="robot_description" value="$(command 'xacro $(var urdf_path)')" />
    <param name="parameters" value="$(find-pkg-share my_robot_description)/config/controllers.yaml"/>
</node>

<node pkg="controller_manager" exec="spawner" args="wheel_controller"/>

<node pkg="rviz2" exec="rviz2"
      args="-d $(var rviz_config_path)" />
          
</launch>